# ============================================================
# 🎮 Vira Discord Bot - Environment Variables
# ============================================================
# این فایل را کپی کنید به .env و مقادیر واقعی را وارد کنید.
# هرگز فایل .env اصلی را در Git قرار ندهید!
# ============================================================

# ─── محیط اجرا ─────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# ─── Discord ────────────────────────────────────────────────
# از: https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-application-client-id
# فقط برای محیط Development (deploy سریع‌تر)
# DISCORD_GUILD_ID=your-test-server-id

# ─── LLM - Ollama (محلی - پیشنهادی) ────────────────────────
OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=30000
OLLAMA_KEEP_ALIVE=5m

# ─── LLM - OpenRouter (ابری - اختیاری) ─────────────────────
OPENROUTER_ENABLED=false
# OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_HEAVY=qwen/qwen-2.5-coder-32b-instruct
OPENROUTER_MODEL_LIGHT=meta-llama/llama-3.1-8b-instruct
OPENROUTER_MODEL_ROUTING=meta-llama/llama-3.1-8b-instruct

# ─── LLM - Provider Selection ───────────────────────────────
LLM_DEFAULT_PROVIDER=ollama
# LLM_FALLBACK_PROVIDER=openrouter

# ─── Generation Params ───────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_STREAMING_ENABLED=true

# ─── Voice (اختیاری - برای آینده) ──────────────────────────
VOICE_ENABLED=false
# STT_PROVIDER=whisper-local
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=fa
# TTS_PROVIDER=edge-tts
# EDGE_TTS_VOICE=fa-IR-DilaraNeural

# ─── Memory ─────────────────────────────────────────────────
CONTEXT_DIRECTORY=./runtime/contexts
MAX_CONTEXT_TOKENS=4096
MAX_CONTEXT_MESSAGES=50

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIRECTORY=./runtime/logs
LOG_PRETTY_PRINT=true
