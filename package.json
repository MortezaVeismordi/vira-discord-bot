{
    "name": "vira-discord-bot",
    "version": "0.1.0",
    "description": "Vira - AI-powered Persian Gamer Discord Bot built with Clean Architecture",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc --project tsconfig.json && tsc-alias",
        "start": "node dist/index.js",
        "start:prod": "cross-env NODE_ENV=production node dist/index.js",
        "lint": "eslint src/ --ext .ts",
        "lint:fix": "eslint src/ --ext .ts --fix",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.33.1",
        "@discordjs/voice": "^0.17.0",
        "axios": "^1.7.9",
        "discord.js": "^14.16.3",
        "dotenv": "^16.4.7",
        "openai": "^4.73.0",
        "p-queue": "^8.0.1",
        "p-retry": "^6.2.1",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "winston": "^3.17.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.1",
        "@typescript-eslint/eslint-plugin": "^8.18.1",
        "@typescript-eslint/parser": "^8.18.1",
        "cross-env": "^7.0.3",
        "eslint": "^9.15.0",
        "jest": "^29.7.0",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.2.5",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
